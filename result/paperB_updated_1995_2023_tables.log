. *---------------------------*
. * 9.2 Start-year window scan for RSS cutoff slope signs
. *---------------------------*
. tempfile t8_window_scan

. postfile t8scan int start_year end_year double cutoff rss ///
>     b_lambda_L se_lambda_L t_lambda_L p_lambda_L ///
>     b_lambda_H se_lambda_H t_lambda_H p_lambda_H ///
>     diff_lambda p_equal_lambda N_model N_countries N_low N_high ///
>     byte low_positive high_negative target_pattern using `t8_window_scan', replace
(file C:\Users\chenyu\AppData\Local\Temp\ST_2cd4_00000v.tmp not found)

. 
. forvalues ys = 1995/2017 {
  2.     use `full_panel', clear
  3.     keep if !is_us & inrange(year, `ys', ${sample_end})
  4.     xtset id year, yearly
  5. 
.     capture quietly regress bond_spreads governance100 debt_ratio G_B vulnerability100 G_X ${ctrls} i.id i.year ///
>         if !missing(bond_spreads, governance100, debt_ratio, G_B, vulnerability100, G_X, ${ctrls_miss}), ///
>         vce(robust)
  6. 
.     if _rc {
  7.         post t8scan (`ys') (${sample_end}) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (0) (0) (0)
  8.         continue
  9.     }
 10. 
.     gen byte theta_sample_scan = e(sample)
 11.     gen double sg_G_hat_scan = _b[governance100] + _b[G_B] * debt_ratio + _b[G_X] * vulnerability100 if theta_sample_scan
 12.     gen double theta_hat_scan = debt_ratio * (-sg_G_hat_scan) if theta_sample_scan
 13.     gen double B_change = F1.debt_ratio - debt_ratio
 14.     gen double G_level = governance100
 15.     gen byte sample_t8 = theta_sample_scan == 1 ///
>         & !missing(B_change, G_level, theta_hat_scan, ${ctrls_miss})
 16. 
.     quietly count if sample_t8 == 1
 17.     if r(N) == 0 {
 18.         post t8scan (`ys') (${sample_end}) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (0) (0) (0)
 19.         continue
 20.     }
 21. 
.     local N_window = r(N)
 22.     quietly levelsof theta_hat_scan if sample_t8 == 1, local(cutoffs8)
 23.     local best_rss .
 24.     local best_cutoff .
 25.     local best_N_low .
 26.     local best_N_high .
 27. 
.     foreach c of local cutoffs8 {
 28.         capture drop t8_low_tmp
 29.         capture drop t8_high_tmp
 30.         capture drop t8_G_low_tmp
 31.         capture drop t8_G_high_tmp
 32.         gen byte t8_low_tmp = theta_hat_scan < `c' if sample_t8 == 1
 33.         gen byte t8_high_tmp = theta_hat_scan >= `c' if sample_t8 == 1
 34. 
.         quietly count if sample_t8 == 1 & t8_low_tmp == 1
 35.         local N_low_tmp = r(N)
 36.         quietly count if sample_t8 == 1 & t8_high_tmp == 1
 37.         local N_high_tmp = r(N)
 38. 
.         if `N_low_tmp' > 0 & `N_high_tmp' > 0 {
 39.             gen double t8_G_low_tmp = G_level * t8_low_tmp if sample_t8 == 1
 40.             gen double t8_G_high_tmp = G_level * t8_high_tmp if sample_t8 == 1
 41. 
.             capture quietly regress B_change t8_G_low_tmp t8_G_high_tmp ${ctrls} i.id i.year ///
>                 if sample_t8 == 1, vce(robust)
 42.             if !_rc {
 43.                 local rss_tmp = e(rss)
 44.                 if missing(`best_rss') | `rss_tmp' < `best_rss' {
 45.                     local best_rss = `rss_tmp'
 46.                     local best_cutoff = `c'
 47.                     local best_N_low = `N_low_tmp'
 48.                     local best_N_high = `N_high_tmp'
 49.                 }
 50.             }
 51.         }
 52.     }
 53. 
.     if missing(`best_cutoff') {
 54.         post t8scan (`ys') (${sample_end}) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (`N_window') (.) (.) (.) (0) (0) (0)
 55.         continue
 56.     }
 57. 
.     capture drop t8_low
 58.     capture drop t8_high
 59.     capture drop t8_G_low
 60.     capture drop t8_G_high
 61.     gen byte t8_low = theta_hat_scan < `best_cutoff' if sample_t8 == 1
 62.     gen byte t8_high = theta_hat_scan >= `best_cutoff' if sample_t8 == 1
 63.     gen double t8_G_low = G_level * t8_low if sample_t8 == 1
 64.     gen double t8_G_high = G_level * t8_high if sample_t8 == 1
 65. 
.     quietly regress B_change t8_G_low t8_G_high ${ctrls} i.id i.year ///
>         if sample_t8 == 1, vce(robust)
 66. 
.     local b_L = _b[t8_G_low]
 67.     local se_L = _se[t8_G_low]
 68.     local t_L = `b_L' / `se_L'
 69.     local p_L = 2 * ttail(e(df_r), abs(`t_L'))
 70. 
.     local b_H = _b[t8_G_high]
 71.     local se_H = _se[t8_G_high]
 72.     local t_H = `b_H' / `se_H'
 73.     local p_H = 2 * ttail(e(df_r), abs(`t_H'))
 74. 
.     quietly test t8_G_low = t8_G_high
 75.     local p_equal = r(p)
 76.     quietly lincom t8_G_low - t8_G_high
 77.     local diff_LH = r(estimate)
 78. 
.     regstats
 79.     local N_model = r(N)
 80.     local N_countries = r(N_countries)
 81.     local low_positive = (`b_L' > 0)
 82.     local high_negative = (`b_H' < 0)
 83.     local target_pattern = (`b_L' > 0 & `b_H' < 0)
 84. 
.     post t8scan (`ys') (${sample_end}) (`best_cutoff') (`best_rss') ///
>         (`b_L') (`se_L') (`t_L') (`p_L') ///
>         (`b_H') (`se_H') (`t_H') (`p_H') ///
>         (`diff_LH') (`p_equal') (`N_model') (`N_countries') (`best_N_low') (`best_N_high') ///
>         (`low_positive') (`high_negative') (`target_pattern')
 85. }
