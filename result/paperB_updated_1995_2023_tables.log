. * 9.3 Start-year window scan for theta-grouped heterogeneity slope signs
. *---------------------------*
. tempfile t9_group_window_scan

. postfile t9scan int start_year end_year byte split double theta_p20 theta_p50 theta_p80 ///
>     b_bottom se_bottom t_bottom p_bottom N_bottom N_countries_bottom r2_bottom ///
>     b_top se_top t_top p_top N_top N_countries_top r2_top ///
>     byte bottom_positive top_negative target_pattern bottom_sig top_sig using `t9_group_window_scan', replace
(file C:\Users\chenyu\AppData\Local\Temp\ST_2cd4_00000w.tmp not found)

. 
. forvalues ys = 1995/2017 {
  2.     use `full_panel', clear
  3.     keep if !is_us & inrange(year, `ys', ${sample_end})
  4.     xtset id year, yearly
  5. 
.     capture quietly regress bond_spreads governance100 debt_ratio G_B vulnerability100 G_X ${ctrls} i.id i.year ///
>         if !missing(bond_spreads, governance100, debt_ratio, G_B, vulnerability100, G_X, ${ctrls_miss}), ///
>         vce(robust)
  6. 
.     if _rc {
  7.         foreach sp in 50 20 {
  8.             post t9scan (`ys') (${sample_end}) (`sp') (.) (.) (.) ///
>                 (.) (.) (.) (.) (.) (.) (.) ///
>                 (.) (.) (.) (.) (.) (.) (.) ///
>                 (0) (0) (0) (0) (0)
  9.         }
 10.         continue
 11.     }
 12. 
.     gen byte theta_sample_scan = e(sample)
 13.     gen double sg_G_hat_scan = _b[governance100] + _b[G_B] * debt_ratio + _b[G_X] * vulnerability100 if theta_sample_scan
 14.     gen double theta_hat_scan = debt_ratio * (-sg_G_hat_scan) if theta_sample_scan
 15.     gen double B_change = F1.debt_ratio - debt_ratio
 16.     gen double G_level = governance100
 17.     gen byte sample_t9 = theta_sample_scan == 1 ///
>         & !missing(B_change, G_level, theta_hat_scan, ${ctrls_miss})
 18. 
.     quietly count if sample_t9 == 1
 19.     if r(N) == 0 {
 20.         foreach sp in 50 20 {
 21.             post t9scan (`ys') (${sample_end}) (`sp') (.) (.) (.) ///
>                 (.) (.) (.) (.) (.) (.) (.) ///
>                 (.) (.) (.) (.) (.) (.) (.) ///
>                 (0) (0) (0) (0) (0)
 22.         }
 23.         continue
 24.     }
 25. 
.     quietly _pctile theta_hat_scan if sample_t9 == 1, p(20 50 80)
 26.     local theta_p20 = r(r1)
 27.     local theta_p50 = r(r2)
 28.     local theta_p80 = r(r3)
 29. 
.     foreach sp in 50 20 {
 30.         local b_bottom .
 31.         local se_bottom .
 32.         local t_bottom .
 33.         local p_bottom .
 34.         local N_bottom .
 35.         local Nc_bottom .
 36.         local r2_bottom .
 37.         local b_top .
 38.         local se_top .
 39.         local t_top .
 40.         local p_top .
 41.         local N_top .
 42.         local Nc_top .
 43.         local r2_top .
 44.         local bottom_sig 0
 45.         local top_sig 0
 46. 
.         if `sp' == 50 {
 47.             local bottom_cond "sample_t9 == 1 & theta_hat_scan <= `theta_p50'"
 48.             local top_cond "sample_t9 == 1 & theta_hat_scan > `theta_p50'"
 49.         }
 50.         else {
 51.             local bottom_cond "sample_t9 == 1 & theta_hat_scan <= `theta_p20'"
 52.             local top_cond "sample_t9 == 1 & theta_hat_scan >= `theta_p80'"
 53.         }
 54. 
.         capture quietly regress B_change G_level ${ctrls} i.id i.year if `bottom_cond', vce(robust)
 55.         if !_rc {
 56.             local b_bottom = _b[G_level]
 57.             local se_bottom = _se[G_level]
 58.             local t_bottom = `b_bottom' / `se_bottom'
 59.             local p_bottom = 2 * ttail(e(df_r), abs(`t_bottom'))
 60.             regstats
 61.             local N_bottom = r(N)
 62.             local Nc_bottom = r(N_countries)
 63.             local r2_bottom = r(r2)
 64.             if !missing(`p_bottom') {
 65.                 if `p_bottom' < 0.01 local bottom_sig 3
 66.                 else if `p_bottom' < 0.05 local bottom_sig 2
 67.                 else if `p_bottom' < 0.10 local bottom_sig 1
 68.             }
 69.         }
 70. 
.         capture quietly regress B_change G_level ${ctrls} i.id i.year if `top_cond', vce(robust)
 71.         if !_rc {
 72.             local b_top = _b[G_level]
 73.             local se_top = _se[G_level]
 74.             local t_top = `b_top' / `se_top'
 75.             local p_top = 2 * ttail(e(df_r), abs(`t_top'))
 76.             regstats
 77.             local N_top = r(N)
 78.             local Nc_top = r(N_countries)
 79.             local r2_top = r(r2)
 80.             if !missing(`p_top') {
 81.                 if `p_top' < 0.01 local top_sig 3
 82.                 else if `p_top' < 0.05 local top_sig 2
 83.                 else if `p_top' < 0.10 local top_sig 1
 84.             }
 85.         }
 86. 
.         local bottom_positive = (!missing(`b_bottom') & `b_bottom' > 0)
 87.         local top_negative = (!missing(`b_top') & `b_top' < 0)
 88.         local target_pattern = (`bottom_positive' == 1 & `top_negative' == 1)
 89. 
.         post t9scan (`ys') (${sample_end}) (`sp') (`theta_p20') (`theta_p50') (`theta_p80') ///
>             (`b_bottom') (`se_bottom') (`t_bottom') (`p_bottom') (`N_bottom') (`Nc_bottom') (`r2_bottom') ///
>             (`b_top') (`se_top') (`t_top') (`p_top') (`N_top') (`Nc_top') (`r2_top') ///
>             (`bottom_positive') (`top_negative') (`target_pattern') (`bottom_sig') (`top_sig')
 90.     }
 91. }
